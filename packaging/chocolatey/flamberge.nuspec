<?xml version="1.0" encoding="utf-8"?>
<!-- Chocolatey package. Build with `choco pack` from this directory, then
     `choco push flamberge.0.1.0.nupkg` to chocolatey.org. See packaging/README.md. -->
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>flamberge</id>
    <version>0.1.0</version>
    <packageSourceUrl>https://github.com/kessriga/flamberge/tree/main/packaging/chocolatey</packageSourceUrl>
    <owners>kessriga</owners>
    <title>flamberge (Install)</title>
    <authors>Kessriga Jeukal</authors>
    <projectUrl>https://github.com/kessriga/flamberge</projectUrl>
    <projectSourceUrl>https://github.com/kessriga/flamberge</projectSourceUrl>
    <docsUrl>https://github.com/kessriga/flamberge#readme</docsUrl>
    <bugTrackerUrl>https://github.com/kessriga/flamberge/issues</bugTrackerUrl>
    <licenseUrl>https://github.com/kessriga/flamberge/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <tags>flamberge drm ebook kindle epub calibre cli</tags>
    <summary>Command-line DRM removal for ebooks (DeDRM_tools, reimplemented in Rust)</summary>
    <description>flamberge removes DRM from ebooks, reimplementing the DeDRM_tools Calibre plugins in Rust. It supports the Mobipocket, Topaz, KFX, Adobe ADEPT (EPUB+PDF), Barnes &amp; Noble (EPUB+PDF), eReader, and Kobo KEPUB schemes, plus offline key generators and on-host key extraction for Kindle, Adobe, and Kobo.</description>
    <releaseNotes>https://github.com/kessriga/flamberge/releases/tag/v0.1.0</releaseNotes>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
